# ====================================================================
# RentTrack — Environment Variables
# Copy this file to .env and fill in real values for local development.
# NEVER commit .env to git.
# ====================================================================

# ===== Django Core =====
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=dev-secret-change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ===== Database =====
DATABASE_URL=postgres://renttrack:renttrack@db:5432/renttrack
# For local (non-Docker) development:
# DATABASE_URL=postgres://renttrack:renttrack@localhost:5432/renttrack

# ===== Redis =====
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ===== Auth / JWT =====
JWT_SECRET=dev-jwt-secret-change-me
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=30

# ===== CORS =====
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ===== Email (Production: SendGrid / AWS SES) =====
# For dev, use Mailhog:
EMAIL_HOST=mailhog
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
DEFAULT_FROM_EMAIL=noreply@renttrack.local
# Production:
# SENDGRID_API_KEY=
# AWS_SES_ACCESS_KEY_ID=
# AWS_SES_SECRET_ACCESS_KEY=

# ===== SMS (MSG91 for India, Twilio for international) =====
MSG91_AUTH_KEY=
MSG91_SENDER_ID=RENTRK
MSG91_TEMPLATE_ID_OTP=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ===== Payments =====
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ===== Object Storage =====
# Local dev uses local filesystem. Production uses S3.
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=renttrack-dev
AWS_S3_REGION_NAME=ap-south-1

# ===== Observability =====
SENTRY_DSN=
LOG_LEVEL=INFO

# ===== Frontend (Vite) =====
VITE_API_URL=http://localhost:8000/api/v1
VITE_WS_URL=ws://localhost:8000/ws
VITE_RAZORPAY_KEY_ID=
VITE_SENTRY_DSN=
